<!doctype html><html lang="ja"><head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>株式会社room404</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:-apple-system,BlinkMacSystemFont,"Helvetica Neue",sans-serif}
body{background:#000;color:#fff;overflow-x:hidden}
#ppt{height:100vh;display:flex;align-items:center;justify-content:center;position:relative;background:#000}
#ppt img{width:100%;height:100%;object-fit:contain;background:#000}
#ppt .g{position:absolute;bottom:26px;left:50%;transform:translateX(-50%);font-size:12px;opacity:.7;letter-spacing:.18em;animation:b 1.6s infinite;user-select:none}
@keyframes b{0%{opacity:.2}50%{opacity:.9}100%{opacity:.2}}
.nav{position:fixed;top:0;left:0;width:100%;padding:18px 8vw;display:flex;justify-content:space-between;align-items:center;background:rgba(0,0,0,.78);backdrop-filter:blur(8px);z-index:30}
.nav a{color:#fff;text-decoration:none;margin-left:22px;font-weight:700;cursor:pointer}
.nav a:hover{opacity:.65}
.sec{min-height:100vh;padding:120px 8vw;background:#0a0a0a}
h1{font-size:46px;margin:0 0 26px}
p{opacity:.8;line-height:1.9}
.fake404{position:fixed;inset:0;background:#000;display:flex;align-items:center;justify-content:center;font-size:38px;opacity:0;pointer-events:none;z-index:80;text-align:center;padding:24px}
.fake404.on{opacity:1;pointer-events:auto}
.modal{position:fixed;inset:0;display:none;align-items:center;justify-content:center;z-index:70}
.modal.on{display:flex}
.modal .bg{position:absolute;inset:0;background:rgba(0,0,0,.72);backdrop-filter:blur(8px)}
.card{position:relative;width:min(560px,92vw);border:1px solid rgba(255,255,255,.16);border-radius:18px;padding:18px;background:rgba(255,255,255,.06)}
.card .t{font-size:12px;opacity:.7;letter-spacing:.3px;margin-bottom:10px}
.in{width:100%;padding:14px 12px;border-radius:14px;border:1px solid rgba(255,255,255,.18);background:rgba(0,0,0,.35);color:#fff;font-size:16px;outline:none}
.row{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}
.btn{padding:11px 14px;border-radius:14px;border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.06);color:#fff;font-weight:800;cursor:pointer}
.btn.pri{background:rgba(20,99,255,.25)}
.msg{margin-top:10px;font-size:12px;opacity:.85}
.small{font-size:12px;opacity:.75}
label{font-size:12px;opacity:.8;display:block;margin:10px 0 6px}
select,textarea{width:100%;padding:12px;border-radius:14px;border:1px solid rgba(255,255,255,.18);background:rgba(0,0,0,.35);color:#fff;outline:none}
textarea{min-height:96px;resize:vertical}
</style></head><body>

<section id="ppt"><img src="hero.jpg" alt="room404"><div class="g">SCROLL</div></section>

<div class="nav">
  <div id="brand" data-g30>room404</div>
  <div>
    <a data-g30 onclick="show404()">企業理念</a>
    <a data-g30 onclick="show404()">事業内容</a>
    <a data-g30 onclick="show404()">採用情報</a>
    <a data-g30 onclick="openEntry()">お問い合わせ</a>
  </div>
</div>

<section class="sec" id="top" data-g30>
  <h1 data-g30>株式会社room404</h1>
  <p data-g30>現在、一部ページで不具合が発生しています。</p>
  <p class="small" data-g30 style="margin-top:10px">※スクロールで“公式サイト風”に遷移します</p>
</section>

<!-- 入室コード：お問い合わせ→モーダル -->
<div class="modal" id="mEntry">
  <div class="bg" onclick="closeAll()"></div>
  <div class="card">
    <div class="t" data-g30>ROOM404://ENTRY</div>
    <div style="font-size:26px;font-weight:900;margin:2px 0 10px" data-g30>入室コード</div>
    <p class="small" data-g30>入力後に「あなたの現在の状況（アンケート）」へ進みます。</p>
    <!-- ここだけは“入力文字”を壊したくないので data-no-garble を付与 -->
    <input id="entryCode" class="in" data-no-garble placeholder="例）room404 / kento2026" autocomplete="off">
    <div class="row">
      <button class="btn pri" onclick="goSurvey()">入室して進む</button>
      <button class="btn" onclick="skipEntry()">入力せず進む</button>
      <button class="btn" onclick="closeAll()">閉じる</button>
    </div>
    <div class="msg" id="entryMsg" data-g30></div>
  </div>
</div>

<!-- アンケート：ここは一切文字化けさせない -->
<section class="sec" id="survey" data-no-garble style="background:#050505">
  <h1>あなたの現在の状況</h1>
  <p>※任意／未入力でも進めます</p>

  <div class="card" style="margin-top:18px" data-no-garble>
    <div class="t">ROOM404://STATUS</div>

    <label>Q1 現在、4月の入社に向けてどの程度不安を感じていますか？（1〜10）</label>
    <select id="q1">
      <option value="">選択してください</option>
      <option>1</option><option>2</option><option>3</option><option>4</option><option>5</option>
      <option>6</option><option>7</option><option>8</option><option>9</option><option>10</option>
    </select>

    <label>Q2 入社にあたって特に不安な点は？（複数可の代替：代表1つ選択）</label>
    <select id="q2">
      <option value="">選択してください</option>
      <option>同期となじめるか不安（横）</option>
      <option>先輩社員とうまくコミュニケーションがとれるか不安（縦）</option>
      <option>業務に必要なスキル・能力が足りているか不安（内側）</option>
      <option>論理的思考やアウトプットができるか不安（内側）</option>
      <option>会社の雰囲気や文化についていけるか不安（外側）</option>
      <option>配属後のキャリアパス</option>
      <option>その他</option>
    </select>

    <label>Q3 Q2の不安について、どの程度不安ですか？（1〜10）</label>
    <select id="q3">
      <option value="">選択してください</option>
      <option>1</option><option>2</option><option>3</option><option>4</option><option>5</option>
      <option>6</option><option>7</option><option>8</option><option>9</option><option>10</option>
    </select>

    <label>Q4 基本情報の勉強で障壁と感じる要素は？</label>
    <select id="q4">
      <option value="">選択してください</option>
      <option>可処分時間の不足</option>
      <option>取得の目的が不透明</option>
      <option>何から手をつければいいかわからない</option>
      <option>勉強法がわからない</option>
      <option>学びの成果が実感できない</option>
      <option>その他</option>
    </select>

    <label>Q5 Q4の障壁について、どの程度不安ですか？（1〜10）</label>
    <select id="q5">
      <option value="">選択してください</option>
      <option>1</option><option>2</option><option>3</option><option>4</option><option>5</option>
      <option>6</option><option>7</option><option>8</option><option>9</option><option>10</option>
    </select>

    <label>ひとこと（任意）</label>
    <textarea id="free" placeholder="任意"></textarea>

    <div class="row">
      <button class="btn pri" onclick="submitSurvey()">送信して戻る</button>
      <button class="btn" onclick="skipSurvey()">スキップして戻る</button>
    </div>
    <div class="msg" id="surveyMsg"></div>
  </div>
</section>

<div class="fake404" id="f404">404 Not Found...</div>

<script>
(()=>{"use strict";
const POOL="01/|_-=+*#@$%!?<>[]{}̷̸̶̵̶̵̝̳͚̱̬̻̿̄̒̅͗̈́̿͝͠͝";
const g30=el=>el?.getAttribute("data-g30")!=null;
const noG=el=>el?.closest?.("[data-no-garble]")||el?.getAttribute?.("data-no-garble")!=null;

function garble(s,keep=.7){
  let o=""; for(let i=0;i<s.length;i++){
    const c=s[i]; if(c===" "||c==="\n"){o+=c;continue}
    o+=Math.random()<keep?c:POOL[Math.random()*POOL.length|0];
  } return o;
}
const ORI=new WeakMap(), TIM=new WeakMap();

function start30(el){
  if(!el||noG(el)) return;
  if(!ORI.has(el)) ORI.set(el, el.textContent);
  const base=ORI.get(el)||"";
  const t=setInterval(()=>{ el.textContent=garble(base,.7); },90);
  TIM.set(el,t);
}
function stop30(el){ const t=TIM.get(el); if(t){clearInterval(t);TIM.delete(el)} if(ORI.has(el)) el.textContent=ORI.get(el); }

function apply30(){
  document.querySelectorAll("[data-g30]").forEach(el=>{
    if(noG(el)) return;
    start30(el);
  });
}

function flash404(ms=900){
  const f=document.getElementById("f404"); if(!f) return;
  f.classList.add("on");
  const base="404 Not Found...";
  f.textContent=base;
  if(!ORI.has(f)) ORI.set(f,base);
  const t=setInterval(()=>{ f.textContent=garble(base,.7); },70);
  setTimeout(()=>{clearInterval(t); f.classList.remove("on"); f.textContent=base;},ms);
}
window.show404=()=>flash404(900);

const mE=document.getElementById("mEntry");
window.openEntry=()=>{
  flash404(490);
  setTimeout(()=>{ mE.classList.add("on"); apply30(); },520);
};
window.closeAll=()=>{ mE.classList.remove("on"); document.getElementById("entryMsg").textContent=""; };

window.goSurvey=()=>{
  const v=(document.getElementById("entryCode").value||"").trim();
  const msg=document.getElementById("entryMsg");
  msg.textContent=v?("OK: 入室しました："+v):"OK: 入室しました（未入力）";
  flash404(490);
  setTimeout(()=>{ document.getElementById("survey").scrollIntoView({behavior:"smooth",block:"start"}); },520);
};
window.skipEntry=()=>{ document.getElementById("entryCode").value=""; window.goSurvey(); };

window.submitSurvey=()=>{
  document.getElementById("surveyMsg").textContent="OK: 送信しました（ローカル記録）";
  try{
    const payload={t:Date.now(),
      q1:val("q1"),q2:val("q2"),q3:val("q3"),q4:val("q4"),q5:val("q5"),
      free:(document.getElementById("free").value||"").slice(0,120)
    };
    const k="room404_survey_v2";
    const arr=JSON.parse(localStorage.getItem(k)||"[]"); arr.push(payload);
    localStorage.setItem(k,JSON.stringify(arr));
  }catch(e){}
  flash404(900);
  setTimeout(()=>{ document.getElementById("top").scrollIntoView({behavior:"smooth",block:"start"}); },1100);
};
window.skipSurvey=()=>{
  document.getElementById("surveyMsg").textContent="OK: スキップしました";
  flash404(900);
  setTimeout(()=>{ document.getElementById("top").scrollIntoView({behavior:"smooth",block:"start"}); },1100);
};
function val(id){return (document.getElementById(id).value||"").trim()}

apply30();

/* tests */
function assert(c,m){ if(!c) throw new Error("Test failed: "+m); }
function runTests(){
  assert(typeof window.openEntry==="function","openEntry exists");
  assert(typeof window.show404==="function","show404 exists");
  assert(document.querySelector("[data-g30]"),"has garble targets");
  assert(document.querySelector("[data-no-garble]"),"has no-garble area");
  console.log("[room404 test] ok");
}
try{ if(new URLSearchParams(location.search).get("test")==="1") runTests(); }catch(e){}
})();
</script>
</body></html>
